JWT_SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

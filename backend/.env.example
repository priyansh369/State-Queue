JWT_SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=statq

# Gmail SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@hospital.com

# Email Token Settings
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# Optional Twilio SMS settings
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_SOON_THRESHOLD_MINUTES=10
SMS_SOON_COOLDOWN_MINUTES=15
